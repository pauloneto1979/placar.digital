NODE_ENV=production
APP_NAME=placar.digital
PORT=3002
API_PREFIX=/api/v1

# Ajuste para o banco criado na VPS.
DATABASE_URL=postgres://placar_user:TROQUE_A_SENHA@127.0.0.1:5432/placar_digital
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
DB_SSL=false

# Gere com: openssl rand -hex 48
AUTH_TOKEN_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_COM_32_CARACTERES_OU_MAIS
AUTH_TOKEN_EXPIRES_IN_SECONDS=86400
AUTH_SELECTION_TOKEN_EXPIRES_IN_SECONDS=600

# Dominios autorizados, separados por virgula.
CORS_ORIGINS=https://placar.digital,https://www.placar.digital
TRUST_PROXY=loopback, linklocal, uniquelocal
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=1mb
UPLOAD_DIR=/var/www/placar.digital/shared/uploads

INFINITEPAY_API_URL=https://api.checkout.infinitepay.io
INFINITEPAY_HANDLE=
